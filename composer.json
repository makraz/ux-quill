{
    "name": "makraz/ux-quill",
    "type": "symfony-bundle",
    "description": "Symfony UX Bundle to integrate the Quill rich text editor into Symfony forms",
    "keywords": [
        "symfony-ux",
        "symfony ux",
        "symfony form",
        "symfony wysiwyg",
        "symfony quill",
        "symfony ux bundle",
        "quill",
        "quilljs",
        "rich text editor",
        "wysiwyg",
        "easyadmin",
        "easyadmin wysiwyg"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Hamza Makraz",
            "homepage": "https://github.com/makraz"
        }
    ],
    "homepage": "https://github.com/makraz/ux-quill",
    "support": {
        "issues": "https://github.com/makraz/ux-quill/issues",
        "source": "https://github.com/makraz/ux-quill"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.1.0",
        "symfony/stimulus-bundle": "^2.9.1",
        "symfony/twig-bundle": "^6.4|^7.0|^8.0",
        "symfony/form": "^6.4|^7.0|^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5|^10.0|^11.0",
        "friendsofphp/php-cs-fixer": "^3.1",
        "symfony/browser-kit": "^6.4|^7.0|^8.0",
        "symfony/framework-bundle": "^6.4|^7.0|^8.0",
        "symfony/asset-mapper": "^6.4|^7.0|^8.0",
        "easycorp/easyadmin-bundle": "^4.7"
    },
    "autoload": {
        "psr-4": {
            "Makraz\\QuillBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Makraz\\QuillBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true
        }
    },
    "extra": {
        "thanks": {
            "name": "symfony/ux",
            "url": "https://github.com/symfony/ux"
        }
    }
}
